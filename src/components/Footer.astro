---
import { site } from '../data/site';
---

<div style="border-top:1px solid var(--border)">
  <div
    class="container"
    style="padding:32px 24px;display:flex;justify-content:space-between;align-items:center;gap:16px;flex-wrap:wrap"
  >
    <div style="font-size:15px;color:var(--muted)">{site.name}.tech © {site.year}</div>
    <a href={site.telegramUrl} target="_blank" rel="noopener noreferrer" class="mono" style="font-size:14px;color:var(--muted)">
      t.me/{site.telegramHandle.replace('@', '')}
    </a>
  </div>
</div>
