---
import { site } from '../data/site';
import { useTranslations, type Lang } from '../i18n/ui';

interface Props {
  lang?: Lang;
}

const { lang = 'ru' } = Astro.props;
const t = useTranslations(lang);
---

<a
  href={site.telegramUrl}
  target="_blank"
  rel="noopener noreferrer"
  class="btn btn-primary"
  style="position:fixed;right:clamp(16px,3vw,24px);bottom:clamp(16px,3vw,24px);z-index:48;font-size:16px;padding:14px 22px;border-radius:999px;box-shadow:0 8px 32px rgba(0,0,0,0.5)"
>
  {t('cta.telegram')}
</a>
