---
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/Button.astro';
import { site } from '../../data/site';

const stats = [
  { n: '6 years', l: 'in development' },
  { n: '42 projects', l: 'launched' },
  { n: '10 countries', l: 'projects worldwide' },
];

const approach = [
  'I understand the business first, then write the code',
  "I tell you what not to build — saving the client's budget",
  "I'm accountable for the result, not the lines of code",
];
---

<Layout title="About" lang="en">
  <div style="max-width:1000px;margin:0 auto;padding:clamp(104px,16vw,140px) 20px clamp(56px,10vw,96px)">
    <div class="grid-auto" style="align-items:center;gap:48px;margin-bottom:80px">
      <div class="card" style="overflow:hidden;aspect-ratio:1">
        <img src="/images/author.jpg" alt="Photo" style="width:100%;height:100%;object-fit:cover" width="640" height="640" />
      </div>
      <div>
        <div class="eyebrow" style="margin-bottom:20px">ABOUT ME</div>
        <h1 style="margin:0 0 24px;font-size:clamp(30px,4vw,48px);font-weight:800;letter-spacing:-0.03em">
          {site.name}.tech
        </h1>
        <p style="margin:0;font-size:18px;line-height:1.7">
          I'm a product engineer with a background in development and business. I don't just write code —
          I think about how the product makes money. Behind every project I see a business problem, not just a spec.
        </p>
      </div>
    </div>

    <div class="grid-auto" style="grid-template-columns:repeat(auto-fit,minmax(220px,1fr));margin-bottom:80px">
      {
        stats.map((s) => (
          <div class="card" style="padding:32px">
            <div style="font-size:44px;font-weight:800;letter-spacing:-0.02em;margin-bottom:8px">{s.n}</div>
            <div style="font-size:16px;color:var(--muted)">{s.l}</div>
          </div>
        ))
      }
    </div>

    <div style="margin-bottom:80px">
      <div class="eyebrow" style="margin-bottom:24px">APPROACH</div>
      <div style="display:flex;flex-direction:column">
        {
          approach.map((text, i) => (
            <div
              style={`display:flex;gap:20px;padding:24px 0;border-top:1px solid var(--border);${i === approach.length - 1 ? 'border-bottom:1px solid var(--border)' : ''};font-size:19px;font-weight:500;line-height:1.5`}
            >
              <span class="mono" style="font-size:14px;color:var(--muted);padding-top:4px">
                {String(i + 1).padStart(2, '0')}
              </span>
              <span>{text}</span>
            </div>
          ))
        }
      </div>
    </div>

    <div style="text-align:center">
      <h2 style="margin:0 0 32px;font-size:clamp(26px,3.5vw,40px);font-weight:700;letter-spacing:-0.02em">
        Let's get in touch
      </h2>
      <Button href={site.telegramUrl} external>Message on Telegram →</Button>
    </div>
  </div>
</Layout>