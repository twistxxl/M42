---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import { site } from '../data/site';

const stats = [
  { n: '6 лет', l: 'опыт в разработке' },
  { n: '22 проекта', l: 'запущено' },
  { n: '6 стран', l: 'проекты по всему миру' },
];

const approach = [
  'Сначала понимаю бизнес, потом пишу код',
  'Говорю что не нужно делать — экономлю бюджет клиента',
  'Отвечаю за результат, а не за строки кода',
];
---

<Layout title="Обо мне">
  <div style="max-width:1000px;margin:0 auto;padding:clamp(104px,16vw,140px) 20px clamp(56px,10vw,96px)">
    <div class="grid-auto" style="align-items:center;gap:48px;margin-bottom:80px">
      <div class="card" style="overflow:hidden;aspect-ratio:1">
        <img src="/images/author.jpg" alt="Фото" style="width:100%;height:100%;object-fit:cover" width="640" height="640" />
      </div>
      <div>
        <div class="eyebrow" style="margin-bottom:20px">ОБО МНЕ</div>
        <h1 style="margin:0 0 24px;font-size:clamp(30px,4vw,48px);font-weight:800;letter-spacing:-0.03em">
          {site.name}.tech
        </h1>
        <p style="margin:0;font-size:18px;line-height:1.7">
          Я продуктовый инженер с опытом в разработке и понимании бизнеса. Не просто пишу код — думаю о том, как
          продукт зарабатывает деньги. За каждым проектом вижу бизнес-задачу, а не техническое задание.
        </p>
      </div>
    </div>

    <div class="grid-auto" style="grid-template-columns:repeat(auto-fit,minmax(220px,1fr));margin-bottom:80px">
      {
        stats.map((s) => (
          <div class="card" style="padding:32px">
            <div style="font-size:44px;font-weight:800;letter-spacing:-0.02em;margin-bottom:8px">{s.n}</div>
            <div style="font-size:16px;color:var(--muted)">{s.l}</div>
          </div>
        ))
      }
    </div>

    <div style="margin-bottom:80px">
      <div class="eyebrow" style="margin-bottom:24px">ПОДХОД</div>
      <div style="display:flex;flex-direction:column">
        {
          approach.map((text, i) => (
            <div
              style={`display:flex;gap:20px;padding:24px 0;border-top:1px solid var(--border);${i === approach.length - 1 ? 'border-bottom:1px solid var(--border)' : ''};font-size:19px;font-weight:500;line-height:1.5`}
            >
              <span class="mono" style="font-size:14px;color:var(--muted);padding-top:4px">
                {String(i + 1).padStart(2, '0')}
              </span>
              <span>{text}</span>
            </div>
          ))
        }
      </div>
    </div>

    <div style="text-align:center">
      <h2 style="margin:0 0 32px;font-size:clamp(26px,3.5vw,40px);font-weight:700;letter-spacing:-0.02em">
        Давайте знакомиться
      </h2>
      <Button href={site.telegramUrl} external>Написать в Telegram →</Button>
    </div>
  </div>
</Layout>
